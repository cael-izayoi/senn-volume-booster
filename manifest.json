{
  "manifest_version": 2,
  "name": "Volume Booster",
  "version": "1.0",
  "description": "Small add-on to change the volume up to 600%",
  "permissions": ["activeTab", "tabs", "storage"],
  "browser_action": {
    "default_popup": "popup.html",
    "default_title": "Volume Booster"
  },
  "icons": {
    "48": "icon.svg"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_start",
      "all_frames": true
    }
  ],
  "web_accessible_resources": ["inject.js"]
}
